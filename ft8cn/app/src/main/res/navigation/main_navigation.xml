<?xml version="1.0" encoding="utf-8"?>
<!--
    Main Navigation Graph for FT8CN Application
    Defines all fragments and their navigation actions
    Order of fragments does NOT affect UI order - that's controlled by bottom_nav_menu.xml
-->
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_navigation"
    app:startDestination="@id/menu_nav_calling_list">

    <!-- ============================================ -->
    <!-- SCAN FRAGMENT (NEW) - Frequency scanning mode -->
    <!-- Allows scanning multiple frequencies and counting new stations -->
    <!-- ============================================ -->
    <fragment
        android:id="@+id/menu_nav_scan"
        android:name="com.bg7yoz.ft8cn.ui.ScanFragment"
        android:label="@string/nav_menu_title_scan"
        tools:layout="@layout/fragment_scan" />

    <!-- ============================================ -->
    <!-- DECODE LIST - Shows decoded FT8 messages from all bands -->
    <!-- Primary view for monitoring activity -->
    <!-- ============================================ -->
    <fragment
        android:id="@+id/menu_nav_calling_list"
        android:name="com.bg7yoz.ft8cn.ui.CallingListFragment"
        android:label="@string/nav_menu_title_decode_list"
        tools:layout="@layout/fragment_calling_list" >
        <!-- Navigation actions from Decode List -->
        <action
            android:id="@+id/action_menu_nav_calling_list_to_menu_nav_mycalling"
            app:destination="@id/menu_nav_mycalling" />
        <action
            android:id="@+id/action_menu_nav_calling_list_to_menu_nav_history"
            app:destination="@id/menu_nav_history" />
    </fragment>

    <!-- ============================================ -->
    <!-- MY CALLING - Transmit queue and CQ calling interface -->
    <!-- Used for responding to calls and initiating contacts -->
    <!-- ============================================ -->
    <fragment
        android:id="@+id/menu_nav_mycalling"
        android:name="com.bg7yoz.ft8cn.ui.MyCallingFragment"
        android:label="@string/nav_menu_title_my_calling"
        tools:layout="@layout/fragment_my_calling" >
        <!-- Navigation action to history/logs -->
        <action
            android:id="@+id/action_menu_nav_mycalling_to_menu_nav_history"
            app:destination="@id/menu_nav_history" />
    </fragment>

    <!-- ============================================ -->
    <!-- CONFIG / SETTINGS - Application configuration -->
    <!-- All user preferences and radio settings -->
    <!-- ============================================ -->
    <fragment
        android:id="@+id/menu_nav_config"
        android:name="com.bg7yoz.ft8cn.ui.ConfigFragment"
        android:label="@string/nav_menu_title_config"
        tools:layout="@layout/fragment_config" />

    <!-- ============================================ -->
    <!-- SPECTRUM - Real-time waterfall display -->
    <!-- Visual representation of audio spectrum for signal analysis -->
    <!-- ============================================ -->
    <fragment
        android:id="@+id/menu_nav_spectrum"
        android:name="com.bg7yoz.ft8cn.ui.SpectrumFragment"
        android:label="@string/spectrum"
        tools:layout="@layout/fragment_spectrum" />

    <!-- ============================================ -->
    <!-- HISTORY / LOGS - QSO and SWL log viewer -->
    <!-- Browse and manage contact history -->
    <!-- ============================================ -->
    <fragment
        android:id="@+id/menu_nav_history"
        android:name="com.bg7yoz.ft8cn.ui.LogFragment"
        android:label="@string/nav_menu_title_history" />

    <!-- ============================================ -->
    <!-- COUNT FRAGMENT - Statistics and counters -->
    <!-- Internal utility fragment (not in bottom nav) -->
    <!-- ============================================ -->
    <fragment
        android:id="@+id/countFragment"
        android:name="com.bg7yoz.ft8cn.count.CountFragment"
        android:label="fragment_count"
        tools:layout="@layout/fragment_count" />

    <!-- ============================================ -->
    <!-- QRZ FRAGMENT - QRZ.com integration -->
    <!-- Lookup callsign information from QRZ database -->
    <!-- ============================================ -->
    <fragment
        android:id="@+id/QRZ_Fragment"
        android:name="com.bg7yoz.ft8cn.ui.QRZ_Fragment"
        android:label="QRZ_Fragment" />

    <!-- ============================================ -->
    <!-- FLEX RADIO INFO - FlexRadio configuration -->
    <!-- Settings specific to FlexRadio SDR devices -->
    <!-- ============================================ -->
    <fragment
        android:id="@+id/flexRadioInfoFragment"
        android:name="com.bg7yoz.ft8cn.ui.FlexRadioInfoFragment"
        android:label="fragment_flex_radio_info"
        tools:layout="@layout/fragment_flex_radio_info" />

    <!-- ============================================ -->
    <!-- XIEGU INFO - Xiegu radio configuration -->
    <!-- Settings specific to Xiegu transceivers -->
    <!-- ============================================ -->
    <fragment
        android:id="@+id/xieguInfoFragment"
        android:name="com.bg7yoz.ft8cn.ui.XieguInfoFragment"
        android:label="fragment_xiegu_info"
        tools:layout="@layout/fragment_xiegu_info" />

</navigation>